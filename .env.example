# Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# LLM Provider — choose one: openai (default), azure, databricks
LLM_PROVIDER=openai

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.4

# --- Azure OpenAI (used when LLM_PROVIDER=azure) ---
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Databricks (used when LLM_PROVIDER=databricks) ---
# DATABRICKS_HOST=https://adb-xxx.azuredatabricks.net
# DATABRICKS_TOKEN=your-databricks-personal-access-token
# DATABRICKS_MODEL=databricks-meta-llama-3-1-70b-instruct
MAX_FILE_SIZE_MB=50
MAX_ROWS_PER_FETCH=100
MAX_CODE_OUTPUT_CHARS=4000
MAX_QUESTION_CHARS=2000
CODE_EXECUTION_TIMEOUT_SECS=10
QUERY_TIMEOUT_SECS=90
UPLOAD_TIMEOUT_SECS=300
MAX_AGENT_ITERATIONS=15
SESSION_CACHE_SIZE=0
SESSION_TTL_HOURS=24
CLEANUP_INTERVAL_HOURS=6
# Storage paths — both must point inside the same Docker volume (/app/data) so
# the SQLite database and uploaded files are stored on the same named volume.
# For local development (outside Docker) change to relative paths, e.g.:
#   DB_PATH=data/spreadsheet_agent.db
#   UPLOADS_DIR=data/uploads
DB_PATH=/app/data/spreadsheet_agent.db
UPLOADS_DIR=/app/data/uploads
LOG_LEVEL=INFO
LOG_FORMAT=text
